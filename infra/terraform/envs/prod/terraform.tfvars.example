aws_region  = "ap-northeast-1"
project     = "auto-trade-repo"
environment = "prod"

# GitHubリポジトリ情報（OIDC認証用）
github_org  = "study-basic-hackathon"
github_repo = "auto-trade-repo"

# デプロイ手順:
#   1. terraform apply -target=module.ecr -target=module.oidc
#   2. output の github_actions_role_arn を GitHub Secrets の AWS_OIDC_ROLE_ARN に設定
#   3. main ブランチに push → GitHub Actions が ECR にイメージを push
#   4. 下記 URI を ECR の実際の URL に更新して terraform apply
nginx_image_uri     = "xxxxxxxxxxxx.dkr.ecr.ap-northeast-1.amazonaws.com/auto-trade-repo/nginx:latest"
api_image_uri       = "xxxxxxxxxxxx.dkr.ecr.ap-northeast-1.amazonaws.com/auto-trade-repo/api:latest"
inference_image_uri = "xxxxxxxxxxxx.dkr.ecr.ap-northeast-1.amazonaws.com/auto-trade-repo/inference:latest"
